# ─────────────────────────────────────────────────────────────
# Cards Center — environment variables
# Kopieer naar .env (lokaal) of zet ze in het Railway-dashboard (productie).
# .env zelf staat in .gitignore — nooit committen.
# ─────────────────────────────────────────────────────────────

# Database ----------------------------------------------------
# LOKAAL: laat DATABASE_URL leeg of zet "file:dev.db" — dan gebruikt de app
#         het lokale SQLite-bestand en is geen token nodig.
# PRODUCTIE (Railway): de Turso libSQL-URL + bijbehorend auth-token.
#   DATABASE_URL="libsql://<jouw-db>-<org>.turso.io"
#   TURSO_AUTH_TOKEN="<turso-token>"
DATABASE_URL="file:dev.db"
TURSO_AUTH_TOKEN=""

# Auth (Auth.js v5) -------------------------------------------
# AUTH_SECRET: genereer met `npx auth secret` of `openssl rand -base64 32`.
# AUTH_TRUST_HOST: op Railway op true zetten (achter reverse proxy).
# NEXTAUTH_URL: de publieke URL van de site (voor links in e-mails).
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="https://<jouw-railway-domein>"

# Publieke site-URL (sitemap, canonical links) ----------------
NEXT_PUBLIC_SITE_URL="https://<jouw-railway-domein>"

# Cron-beveiliging --------------------------------------------
# Gedeeld geheim dat de externe scheduler meestuurt als `Authorization: Bearer`
# naar /api/cron/*. Genereer een willekeurige string.
CRON_SECRET=""

# Bestandsopslag — Cloudflare R2 ------------------------------
# PRODUCTIE (Railway): geüploade foto's gaan naar R2 i.p.v. de containerschijf
#   (die bij elke redeploy gewist wordt). Alle vier vereist om R2 te activeren.
# LOKAAL: laat leeg → upload/serve vallen terug op public/uploads/ op schijf.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Optioneel ---------------------------------------------------
# Image-moderatie via Claude (leeg = uploads gaan ongechecked door — fail-open).
ANTHROPIC_API_KEY=""
# PokeWallet prijs-sync (leeg = sync slaat over).
POKEWALLET_API_KEY=""
# E-mail blijft mock/console totdat Fase 16 een echte provider toevoegt.
# EMAIL_PROVIDER=""
