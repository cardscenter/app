generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// AUTH & USER
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  displayName   String    @unique
  firstName     String?
  lastName      String?
  bio           String?
  avatarUrl     String?
  profileBanner     String?   // e.g. "beginner" — references tier banner image
  profileEmblem     String?   // Cosmetic emblem key (frame around avatar)
  profileBackground String?   // Cosmetic animated background key

  // Ember (cosmetic currency)
  emberBalance      Int       @default(0)
  bonusXP           Int       @default(0)  // XP from recycled duplicates
  loginStreak       Int       @default(0)  // Current consecutive login days (0-7)
  lastLoginDate     String?               // ISO date string of last login reward (YYYY-MM-DD)

  // Wallet
  balance         Float     @default(0)
  heldBalance     Float     @default(0) // Escrow: held until buyer confirms delivery
  reservedBalance Float     @default(0) // Reserved by active auction bids (15% of bid amount, Fase 29)

  // Bank transfer
  bankTransferReference String? @unique // e.g. "atomicsnipz8729376290"

  // Verification (Fase 32 — uitgebreid van enkel ID naar 3 trust-types)
  // ID = paspoort/ID/rijbewijs upload → admin review (gate voor bids ≥ €2000)
  // IBAN = match tussen User.iban en gebruikte rekening bij bank-storting (auto via admin confirmBankTransfer)
  // ADDRESS = officieel adres-document (belastingdienst/utility/bank/gemeente) → admin review (trust-signal)
  isVerified                Boolean  @default(false)  // ID
  isIbanVerified            Boolean  @default(false)  // Bank-rekening
  isAddressVerified         Boolean  @default(false)  // Adres-document
  verificationStatus        String   @default("NONE") // ID-status: NONE | PENDING | APPROVED | REJECTED
  addressVerificationStatus String   @default("NONE") // ADDRESS-status: NONE | PENDING | APPROVED | REJECTED
  // IBAN heeft geen aparte status — gaat automatisch via admin's bank-transfer confirm

  // Suspension (Fase 8). suspendedUntil null = niet opgeschort.
  // PERMANENT: suspendedUntil heeft geen einddatum-betekenis (datum ver in
  // toekomst gezet voor zoek-eenvoud).
  suspendedUntil    DateTime?
  suspensionType    String?   // TEMPORARY | PERMANENT
  suspensionReason  String?
  suspensionAdminId String?

  // Veiling-wanbetalingen (Fase 29). Strike-counter — bij wanbetaling op een
  // veiling +1, bij 2× = auto-suspend 30d, bij 3× = permanent. Decay −1 na
  // 365 dagen zonder nieuwe failure (cron payment-failure-decay).
  paymentFailureCount  Int      @default(0)
  paymentFailureLastAt DateTime?

  // Borg-vrijstelling (Fase 29) — admin-toggle voor BUSINESS-accounts met
  // valide vatNumber + cocNumber. Vrijstelling van verified-eis bij ≥€2500
  // bids; borg-forfait blijft van toepassing bij wanbetaling.
  isBusinessBidExempt Boolean @default(false)

  // IP-tracking voor anti-shill-bidding (Fase 29). Snapshot bij login/session
  // refresh. Geen historie — overschreven bij elke nieuwe login.
  lastLoginIp   String?
  lastLoginIpAt DateTime?

  // Account type & role
  accountType       String   @default("FREE") // FREE | PRO | UNLIMITED | ENTERPRISE | ADMIN
  premiumExpiresAt  DateTime?

  // Tier-based denormalisatie (Fase 31). Search-boost queries sorteren op
  // dit veld: FREE=1, PRO=2, UNLIMITED=3, ENTERPRISE=4. Gevuld in
  // upgradeToTier + downgrade-cron + grace-expiry-cron.
  tierRank          Int      @default(1)

  // Vanity shop URL (Fase 31) — Unlimited+ users kunnen /winkel/<slug>
  // claimen die naar /verkoper/<userId> redirect. Lowercase a-z 0-9 -, 3-32 chars.
  shopSlug          String?  @unique

  // Featured-listing quota (Fase 31). Per-tier maandelijks aantal gratis
  // HOMEPAGE_SPOTLIGHTs. Reset door reset-free-upsells cron op de 1e.
  freeUpsellsRemaining Int      @default(0)
  freeUpsellsResetAt   DateTime?

  // Bid-confirmation modal preference (Fase 31). True = modal nooit tonen,
  // bid wordt direct geplaatst. Default false = standaard modal voor eerste
  // bod per veiling (per-veiling tracking client-side via localStorage).
  skipBidConfirmation Boolean @default(false)

  // Mollie recurring-billing customer ID (Fase 31). Hergebruikt over
  // meerdere subscription-cycli zodat Mollie weet om welke klant het gaat.
  mollieCustomerId  String?

  // Account kind (individual vs business)
  accountKind       String   @default("INDIVIDUAL") // INDIVIDUAL | BUSINESS
  companyName       String?
  vatNumber         String?  // BTW-nummer
  cocNumber         String?  // KVK / Chamber of Commerce number

  // Address
  street        String?
  houseNumber   String?
  postalCode    String?
  city          String?
  country       String?  // ISO 3166-1 alpha-2: "NL", "DE", "BE", etc.

  // Shipping preferences
  // Fase 33: "DOMESTIC_ONLY" | "DOMESTIC_AND_NEAR" | "ALL_EU".
  // Legacy values "NL_ONLY"/"NL_BE" worden tijdens migratie gemapt naar DOMESTIC_ONLY/DOMESTIC_AND_NEAR.
  sellingCountries  String    @default("DOMESTIC_AND_NEAR")

  // Registration preferences
  accountFocus      String?   // BUYING | SELLING | BOTH
  referralSource    String?   // How the user found the platform
  termsAcceptedAt   DateTime? // When the user accepted terms & conditions

  // Username change tracking
  lastUsernameChange DateTime?

  // Address change tracking — 30-dagen cooldown na elke wijziging om
  // anti-fraude redenen. Null = nog nooit gewijzigd, eerste keer is gratis.
  lastAddressChange  DateTime?

  // Runner-up auction setting (max cascade hops when winners fail to pay).
  // Cap is 0..3 (4e bieder maximaal). Default 2 sinds Fase 33-followup.
  maxRunnerUpAttempts Int @default(2)

  // Bank details for payouts (Fase 5)
  iban               String?
  accountHolderName  String?
  lastIbanChange     DateTime?

  // E-mailverificatie (Fase 37). Gevuld zodra user de verify-link uit hun
  // welkom-mail klikt — of automatisch bij Google-OAuth signup (Google-verified).
  // Niet blokkerend voor functionaliteit — alleen visuele nudge via dashboard-banner.
  emailVerifiedAt    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  usernameHistory        UsernameHistory[]
  verificationRequests   VerificationRequest[]
  auctions          Auction[]
  sellerShippingMethods SellerShippingMethod[]
  auctionBids       AuctionBid[]
  claimsales        Claimsale[]
  purchasedItems    ClaimsaleItem[]    @relation("Buyer")
  shippingBundlesAsBuyer  ShippingBundle[] @relation("BundleBuyer")
  shippingBundlesAsSeller ShippingBundle[] @relation("BundleSeller")
  transactions      Transaction[]
  conversationParticipants ConversationParticipant[]
  sentMessages      Message[]          @relation("SentMessages")
  listings          Listing[]
  purchasedListings Listing[]  @relation("ListingBuyer")
  watchlistItems    Watchlist[]
  notifications     Notification[]
  reviewsGiven      Review[]       @relation("ReviewsGiven")
  reviewsReceived   Review[]       @relation("ReviewsReceived")
  autoBids          AutoBid[]
  cartItems         CartItem[]
  disputesOpened    Dispute[]  @relation("DisputesOpened")
  subscriptions     Subscription[]
  claimedItems      ClaimsaleItem[]    @relation("ClaimedBy")

  // Cosmetic / Ember relations
  ownedItems          OwnedItem[]
  emberTransactions   EmberTransaction[]
  activityLogs        ActivityLog[]
  achievements        UserAchievement[]

  // Card-database (Fase 4)
  cardWatchlist       CardWatchlist[]

  // Buyback / Inkoop
  buybackRequests     BuybackRequest[]

  // Uitbetaalsysteem (Fase 6)
  withdrawalRequests       WithdrawalRequest[] @relation("WithdrawalUser")
  reviewedWithdrawalRequests WithdrawalRequest[] @relation("WithdrawalReviewer")

  // Blokkeren + rapporteren (Fase 7)
  blocks            UserBlock[]  @relation("Blocker")
  blockedBy         UserBlock[]  @relation("Blocked")
  reportsFiled      UserReport[] @relation("Reporter")
  reportsReceived   UserReport[] @relation("Reported")
  reportsReviewed   UserReport[] @relation("ReportReviewer")

  // Annuleringsverzoeken (Fase 9)
  cancellationProposed CancellationRequest[] @relation("CancellationProposer")
  cancellationResponded CancellationRequest[] @relation("CancellationResponder")

  // Admin audit log (Fase 15)
  adminAuditLogs    AdminAuditLog[] @relation("AdminAuditLogActor")

  // Bundle-offer + Pickup (Fase 27)
  bundleProposalsAsBuyer  BundleProposal[] @relation("BundleProposalBuyer")
  bundleProposalsAsSeller BundleProposal[] @relation("BundleProposalSeller")
  pickupSchedulesProposed PickupSchedule[] @relation("PickupProposer")

  // Enterprise-aanvragen (Fase 31)
  enterpriseRequests       EnterpriseRequest[] @relation("EnterpriseRequester")
  enterpriseRequestsReviewed EnterpriseRequest[] @relation("EnterpriseReviewer")

  // Runner-up offer-flow (post-Fase-33): expliciete 72u accept/decline-window.
  runnerUpOffersAsBidder AuctionRunnerUpOffer[] @relation("RunnerUpBidder")

  // PendingPlatformFee — niet-inbare boetes/forfaits die bij volgende inkomst
  // automatisch worden afgeroomd. Anti-griefing tegen "saldo leeg houden".
  pendingPlatformFees PendingPlatformFee[]

  // Auth-tokens (Fase 37) — password-reset & e-mailverificatie
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  // Image moderation log
  imageModerationLogs     ImageModerationLog[] @relation("ImageModerationLogUser")

  // Dispute v2 (Fase 40) — greenfield rewrite naast bestaande Dispute-model
  disputesV2OpenedByBuyer  DisputeV2[] @relation("DisputeV2Buyer")
  disputesV2OnMySales      DisputeV2[] @relation("DisputeV2Seller")
  disputesV2ResolvedByAdmin DisputeV2[] @relation("DisputeV2Admin")
  disputeV2EventsCreated   DisputeV2Event[] @relation("DisputeV2EventActor")

  // ShippingIssue (Fase 40) — lightweight admin-tickets voor verloren/vastgelopen pakketten
  shippingIssuesReported   ShippingIssue[] @relation("ShippingIssueReporter")
  shippingIssuesHandled    ShippingIssue[] @relation("ShippingIssueAdmin")
}

// ============================================================
// SELLER SHIPPING METHODS
// ============================================================

model SellerShippingMethod {
  id          String   @id @default(cuid())

  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])

  // Fase 33 (statisch systeem): service+zone identificeren een slot, basisprijs uit catalog.
  // Eén slot per (sellerId, service, zone) — gegarandeerd via @@unique.
  service     String?  // ShippingService: "MAILBOX_PARCEL" | "PARCEL_STANDARD" | "PARCEL_SIGNED". Null = legacy-rij vóór Fase 33.
  zone        String?  // ShippingZone: "DOMESTIC" | "EU_NEAR" | "EU_FAR" | "EU_FAR_ISLAND". Null = legacy-rij.
  priceOverride Float? // Seller-override binnen ±50% van basisprijs. Null = gebruik basePrice uit catalog.

  carrier     String   // "POSTNL", "DHL", "DPD", etc.

  // Legacy-velden (Fase 33: nullable, niet meer gevuld voor nieuwe rijen, drop in fase-2 cleanup)
  serviceName String?
  price       Float?
  countries   String?
  shippingType String?
  isDefault   Boolean  @default(false)
  isTracked   Boolean  @default(false)
  isSigned    Boolean  @default(false)

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claimsaleShippingMethods ClaimsaleShippingMethod[]
  listingShippingMethods   ListingShippingMethod[]
  auctionShippingMethods   AuctionShippingMethod[]
  shippingBundles          ShippingBundle[]

  @@unique([sellerId, service, zone])
  @@index([sellerId])
}

// ============================================================
// CARD CATALOG (TCG → Series → Set)
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique // "Pokémon", "Yu-Gi-Oh!", "Magic: The Gathering"
  slug        String   @unique // "pokemon", "yugioh", "mtg"
  createdAt   DateTime @default(now())

  series      Series[]
}

model Series {
  id            String   @id @default(cuid())
  name          String   // "Base Set Era", "Sword & Shield Era"
  tcgdexSeriesId String? @unique          // TCGdex series id, e.g. "base", "swsh"
  logoUrl       String?                    // TCGdex series logo URL

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())

  cardSets    CardSet[]

  @@index([categoryId])
}

model CardSet {
  id           String   @id @default(cuid())
  name         String   // "Base Set", "Jungle", "Fossil"
  tcgdexSetId  String?  @unique           // Legacy TCGdex set id (e.g. "base1") — kept for image URLs (CDN), no longer used for API calls
  pokewalletSetId   String?  @unique      // PokeWallet numeric set_id (e.g. "24325" for Black Bolt)
  pokewalletSetCode String?               // PokeWallet set_code (e.g. "BLK") — can be null for promos
  logoUrl      String?                     // Set logo URL (TCGdex CDN, static)
  symbolUrl    String?                     // Set symbol URL (TCGdex CDN, static)
  releaseDate  String?                     // ISO date string (e.g. "1999-01-09")
  cardCount    Int?                        // Total cards in set (official count)

  seriesId    String
  series      Series   @relation(fields: [seriesId], references: [id])

  createdAt   DateTime @default(now())

  auctions       Auction[]
  claimsaleItems ClaimsaleItem[]
  listings       Listing[]
  cards          Card[]

  @@index([seriesId])
}

// Card data — IDs are stable TCGdex strings (e.g. "base1-4") for legacy
// reasons; Auction/Listing/ClaimsaleItem reference them via tcgdexId field.
// Pricing data comes from PokeWallet API (api.pokewallet.io) since 2026-04-19.
// Image URLs point to TCGdex CDN (static, no API calls).
model Card {
  id              String   @id              // Stable TCGdex-style id, e.g. "base1-4"
  pokewalletId    String?  @unique          // PokeWallet card ID ("pk_xxx" or hex hash) — used for /cards/{id} lookups
  localId         String                     // "4" within the set
  name            String
  searchName      String?                    // Normalized name for accent/diacritics-insensitive search
  cardSetId       String
  cardSet         CardSet  @relation(fields: [cardSetId], references: [id])
  rarity          String?
  hp              Int?
  types           String?                    // JSON array (e.g. ["Fire"])
  illustrator     String?
  variants        String?                    // JSON: {firstEdition, holo, normal, reverse, wPromo}
  imageUrl        String?                    // TCGdex CDN base URL (append /high.webp at render time)
  imageUrlFull    String?                    // Full image URL from fallback source — used when TCGdex has no image

  // CardMarket EUR pricing — refreshed by PokeWallet sync (variant_type=normal)
  priceAvg        Float?
  priceLow        Float?
  priceTrend      Float?
  priceAvg7       Float?
  priceAvg30      Float?
  // Reverse-holo CardMarket EUR pricing (PokeWallet variant_type=holo)
  priceReverseAvg   Float?
  priceReverseLow   Float?
  priceReverseTrend Float?
  priceReverseAvg7  Float?
  priceReverseAvg30 Float?
  priceUpdatedAt  DateTime?

  // TCGPlayer USD pricing per variant (PokeWallet sub_type_name) — converted to EUR via API
  priceTcgplayerNormalLow      Float?
  priceTcgplayerNormalMid      Float?
  priceTcgplayerNormalMarket   Float?
  priceTcgplayerHolofoilLow    Float?
  priceTcgplayerHolofoilMid    Float?
  priceTcgplayerHolofoilMarket Float?
  priceTcgplayerReverseLow     Float?
  priceTcgplayerReverseMid     Float?
  priceTcgplayerReverseMarket  Float?
  priceTcgplayerUpdatedAt      DateTime?

  // Full immutable gameplay snapshot — JSON blob so the detail page can
  // render attacks/abilities/weakness/resistance/retreat/stage/legal/etc.
  // without any external API calls. Populated by enrichCard and refreshed
  // by the daily cron. Shape: {category, attacks, abilities, weaknesses,
  // resistances, retreat, stage, evolveFrom, dexId, regulationMark, legal,
  // trainerType, energyType, effect}.
  gameplayJson    String?
  // PokéAPI Showdown sprite URL — resolved once per card, never changes
  spriteUrl       String?

  // Lightweight popularity signal for cron prioritization
  viewCount       Int      @default(0)
  lastViewedAt    DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Extra variant-pricing — voor Master Ball / Poke Ball Pattern e.d.
  // JSON-array: [{ label: "Master Ball Pattern", tcgUsd: 1.58, tcgUpdatedAt: "..." }, ...]
  // Pokewallet retourneert deze als aparte card-records met eigen TCGPlayer
  // Holofoil pricing — CardMarket-data is dan een kopie van de basis, dus we
  // gebruiken alleen TCGPlayer voor pattern-pricing.
  priceVariantsJson      String?

  // Manual price override — used for edge cases where CardMarket data is
  // wrong. When set, sync uses these values instead of fetched pricing.
  priceOverrideAvg       Float?
  priceOverrideReverseAvg Float?
  priceOverrideReason    String?

  watchlistEntries CardWatchlist[]
  priceHistory    CardPriceHistory[]

  @@index([cardSetId])
  @@index([name])
  @@index([searchName])
  @@index([priceUpdatedAt])
  @@index([lastViewedAt])
}

// Per-day price snapshot captured when the Card is enriched (via page view
// or cron). One row per (card, day). Enables real 30-day trend charts.
model CardPriceHistory {
  id           String   @id @default(cuid())
  cardId       String
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  date         DateTime                 // UTC midnight of the day
  priceNormal  Float?                   // CardMarket "avg" (normal printing)
  priceReverse Float?                   // CardMarket "avg-holo" (reverse-holo / holo variant)
  createdAt    DateTime @default(now())

  @@unique([cardId, date])
  @@index([cardId])
  @@index([date])
}

model CardWatchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
}

// ============================================================
// AUCTIONS (Veilingen)
// ============================================================

model Auction {
  id            String   @id @default(cuid())
  title         String
  description   String?
  imageUrls     String?  // JSON array of image URLs

  // Auction type
  auctionType   String   @default("SINGLE_CARD") // SINGLE_CARD | MULTI_CARD | COLLECTION | SEALED_PRODUCT | OTHER

  // Card details (for SINGLE_CARD)
  cardName      String?
  cardSetId     String?
  cardSet       CardSet? @relation(fields: [cardSetId], references: [id])
  condition     String?  // "Near Mint", "Lightly Played", "Moderately Played", "Heavily Played", "Damaged"
  tcgdexId      String?  // Stable TCGdex card identifier, e.g. "base1-4"

  // Multi-card details (for MULTI_CARD)
  cardItems     String?  // JSON array: [{cardName, condition, quantity}]

  // Collection details (for COLLECTION)
  estimatedCardCount Int?
  conditionRange     String? // e.g. "Lightly Played - Near Mint"

  // Sealed product details (for SEALED_PRODUCT)
  productType   String?  // BOOSTER | ETB | TIN | BOOSTER_BOX | OTHER_SEALED

  // Other/Collectibles details (for OTHER)
  itemCategory  String?  // "Playmat", "Binder", "Figuur", etc.

  // Seller
  sellerId      String
  seller        User     @relation(fields: [sellerId], references: [id])

  // Pricing
  startingBid   Float
  reservePrice  Float?   // null = without reserve
  buyNowPrice   Float?   // null = no buy-it-now option
  currentBid    Float?   // Denormalized: highest bid so far

  // Timing
  duration      Int      // 3, 5, 7, or 14 (days)
  // startTime is null voor legacy auctions die "live-from-creation" waren.
  // Voor nieuwe auctions: het moment waarop de veiling van SCHEDULED naar
  // ACTIVE flipt. Bij `startTime <= now + 5min` wordt status direct ACTIVE.
  startTime     DateTime?
  endTime       DateTime
  extendedCount Int      @default(0) // Number of anti-snipe extensions

  // Status
  status        String   @default("ACTIVE") // SCHEDULED | ACTIVE | ENDED_SOLD | ENDED_RESERVE_NOT_MET | ENDED_NO_BIDS | BOUGHT_NOW | CANCELLED | AWAITING_PAYMENT | PAYMENT_FAILED
  winnerId      String?
  finalPrice    Float?

  // Payment deadline (for winners with insufficient balance)
  paymentDeadline DateTime?  // 5 days after auction end to complete payment
  paymentStatus   String?    // AWAITING_PAYMENT | AWAITING_RUNNER_UP_DECISION | PAID | PAYMENT_FAILED

  // Runner-up rotation: when the current winner fails to pay, de cron biedt
  // de veiling aan de volgende hoogste bieder (niet in failedBidderIds, niet
  // de huidige winner). De runner-up krijgt 72u om te accepteren/weigeren.
  // Capped op `seller.maxRunnerUpAttempts` (max 3 = top-4-bidders totaal).
  runnerUpEnabled  Boolean @default(true)
  failedBidderIds  String  @default("[]") // JSON array van bidders die al gepasseerd zijn (wanbetaler + decliners + expired)
  runnerUpAttempts Int     @default(0)

  // Delivery (Fase 27.95): SHIP / PICKUP / BOTH. Voor PICKUP/BOTH wordt
  // pickupCity gevuld vanuit User.city bij createAuction. Voor BOTH moet
  // de bidder bij placeBid/setAutoBid een deliveryChoice opgeven; bij
  // finalize wordt de keuze van de winning bid gebruikt voor bundle.deliveryMethod.
  deliveryMethod String  @default("SHIP")
  pickupCity     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bids          AuctionBid[]
  autoBids      AutoBid[]
  conversations Conversation[]
  watchlistItems Watchlist[]
  shippingMethods AuctionShippingMethod[]
  shippingBundle ShippingBundle?
  upsells       AuctionUpsell[]
  labels        AuctionLabel[]
  runnerUpOffers AuctionRunnerUpOffer[]

  @@index([sellerId])
  @@index([status])
  @@index([cardSetId])
  @@index([tcgdexId])
  @@index([status, startTime]) // voor auction-activate cron-query
}

model AuctionLabel {
  id        String   @id @default(cuid())

  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  // GEEN_RESERVE | DIRECT_KOPEN | MOET_NU_WEG | HOT_ITEM | TOPSTAAT | ZELDZAAM | VERZAMELAARSSTUK | NIEUW_UIT_COLLECTIE
  type      String

  // ruby | amber | emerald | sky | violet | rose | indigo | slate | orange | teal
  colorKey  String

  // Snapshot van prijs op creatiemoment (bundle-tarief: 1=€0,99 / 2=€1,69)
  cost      Float

  createdAt DateTime @default(now())

  @@index([auctionId])
}

model AuctionUpsell {
  id         String   @id @default(cuid())

  auctionId  String
  auction    Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  type       String   // HOMEPAGE_SPOTLIGHT | CATEGORY_HIGHLIGHT | URGENT_LABEL
  startsAt   DateTime @default(now())
  expiresAt  DateTime
  dailyCost  Float
  totalCost  Float

  createdAt  DateTime @default(now())

  @@index([auctionId])
  @@index([type, expiresAt])
}

model AuctionShippingMethod {
  id               String               @id @default(cuid())
  auctionId        String
  auction          Auction              @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  shippingMethodId String
  shippingMethod   SellerShippingMethod @relation(fields: [shippingMethodId], references: [id])
  price            Float                // Snapshot of price at creation time

  @@unique([auctionId, shippingMethodId])
  @@index([auctionId])
}

model AuctionBid {
  id         String   @id @default(cuid())
  amount     Float
  createdAt  DateTime @default(now())

  auctionId  String
  auction    Auction  @relation(fields: [auctionId], references: [id])

  bidderId   String
  bidder     User     @relation(fields: [bidderId], references: [id])

  // Fase 27.95: voor BOTH-auctions geeft elke bidder zijn voorkeur op (SHIP/PICKUP).
  // Wordt gebruikt bij finalizeAuction om bundle.deliveryMethod te bepalen.
  // Bij SHIP-only of PICKUP-only auctions blijft dit null (de auction-deliveryMethod
  // bepaalt dan).
  deliveryChoice String?

  // IP-snapshot bij bid-tijd voor anti-shill-bidding-detectie (Fase 29).
  // Wordt na 90d genull't door cron prune-bid-ips. Privacy-policy dekt dit.
  bidderIp String?

  @@index([auctionId, amount])
  @@index([bidderId])
}

// ============================================================
// CLAIMSALES
// ============================================================

model Claimsale {
  id            String   @id @default(cuid())
  title         String
  description   String?
  coverImage    String?  // URL for claimsale thumbnail/cover
  shippingCost  Float

  // CARDS = volledige card-flow (card-selector, condities, variant, marktprijs)
  // ITEMS = vrije velden (naam + omschrijving + eigen conditie-set, geen card-selector)
  type          String   @default("CARDS") // CARDS | ITEMS

  // Status: DRAFT (editable) → SCHEDULED → LIVE (immutable) → CLOSED
  status        String   @default("DRAFT") // DRAFT | SCHEDULED | LIVE | CLOSED
  publishedAt   DateTime?

  // Geplande start (max +5 dagen). null = legacy/direct-live. Bij SCHEDULED flipt
  // de claimsale-activator-scheduler de status naar LIVE zodra startTime ≤ now.
  startTime     DateTime?

  sellerId      String
  seller        User     @relation(fields: [sellerId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         ClaimsaleItem[]
  conversations Conversation[]
  watchlistItems Watchlist[]
  shippingMethods ClaimsaleShippingMethod[]
  upsells       ClaimsaleUpsell[]
  labels        ClaimsaleLabel[]

  @@index([sellerId])
  @@index([status])
  @@index([status, startTime]) // voor claimsale-activate cron-query
}

model ClaimsaleUpsell {
  id          String    @id @default(cuid())

  claimsaleId String
  claimsale   Claimsale @relation(fields: [claimsaleId], references: [id], onDelete: Cascade)

  type        String    // HOMEPAGE_SPOTLIGHT | CATEGORY_HIGHLIGHT | ITEM_PREVIEW
  startsAt    DateTime  @default(now())
  expiresAt   DateTime
  dailyCost   Float
  totalCost   Float

  createdAt   DateTime  @default(now())

  @@index([claimsaleId])
  @@index([type, expiresAt])
}

model ClaimsaleLabel {
  id          String    @id @default(cuid())

  claimsaleId String
  claimsale   Claimsale @relation(fields: [claimsaleId], references: [id], onDelete: Cascade)

  // MOET_NU_WEG | HOT_ITEM | TOPSTAAT | ZELDZAAM | HOLO_FOIL | SNEL_VERZONDEN | NIEUW | OPRUIMING
  type        String

  // ruby | amber | emerald | sky | violet | rose | indigo | slate | orange | teal
  colorKey    String

  // Snapshot van prijs op creatiemoment (bundle-tarief: 1=€0,99 / 2=€1,69)
  cost        Float

  createdAt   DateTime  @default(now())

  @@index([claimsaleId])
}

model ClaimsaleShippingMethod {
  id               String               @id @default(cuid())
  claimsaleId      String
  claimsale        Claimsale            @relation(fields: [claimsaleId], references: [id], onDelete: Cascade)
  shippingMethodId String
  shippingMethod   SellerShippingMethod @relation(fields: [shippingMethodId], references: [id])
  price            Float                // Snapshot of price at creation time

  @@unique([claimsaleId, shippingMethodId])
  @@index([claimsaleId])
}

model ClaimsaleItem {
  id           String   @id @default(cuid())
  cardName     String
  condition    String   // "Near Mint", "Lightly Played", etc.
  price        Float
  reference    String?  // Card number / set reference (e.g. "#4", "SV1-199")
  sellerNote   String?  // Korte referentie-tekst (max 30 tekens), getoond op de listing
  itemDescription String? // Lange per-item omschrijving (alleen ITEMS-type claimsales)
  imageUrls    String   @default("[]") // JSON array of image URLs
  tcgdexId     String?  // Stable TCGdex card identifier, e.g. "base1-4"

  cardSetId    String?
  cardSet      CardSet?  @relation(fields: [cardSetId], references: [id])

  claimsaleId  String
  claimsale    Claimsale @relation(fields: [claimsaleId], references: [id], onDelete: Cascade)

  // Purchase status
  status       String   @default("AVAILABLE") // AVAILABLE | CLAIMED | SOLD | DELETED
  buyerId      String?
  buyer        User?    @relation("Buyer", fields: [buyerId], references: [id])

  // Claim reservation (15 min)
  claimedAt    DateTime?
  claimedById  String?
  claimedBy    User?    @relation("ClaimedBy", fields: [claimedById], references: [id])

  // Bij checkout-start zet `cart.checkout()` deze op now+5min zodat de
  // expire-claims cron de items niet kan opruimen tijdens betalings-flow.
  // Auto-expires na 5 min zodat een vastgelopen checkout items niet
  // permanent blokkeert. Niet renewable bij herhaalde klik (anti-abuse).
  checkoutLockExpiresAt DateTime?

  // (Fase 40) Anti-abuse tegen lock-renewal-exploit: bij `unclaimItem` werd
  // `checkoutLockExpiresAt` gereset, waarna user direct kon reclaimen + opnieuw
  // 5min lock pakken (effectief: indefinite-renewal). Nu trackt deze stamp het
  // laatste unclaim-moment; in `claimItem` cappen we de totaal-alive-time per
  // user+item op een hard window zodat de exploit niet werkt.
  lastUnclaimAt     DateTime?
  lastUnclaimedById String?  // wie het laatst unclaim'de — voor "same user reclaim"-detectie

  refundedAt   DateTime? // Set when seller refunds this item

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Link to shipping bundle
  shippingBundleId String?
  shippingBundle   ShippingBundle? @relation(fields: [shippingBundleId], references: [id])

  cartItems    CartItem[]

  @@index([claimsaleId])
  @@index([cardSetId])
  @@index([buyerId])
  @@index([claimedById])
  @@index([status])
  @@index([tcgdexId])
}

// ============================================================
// MARKTPLAATS (Listings)
// ============================================================

model Listing {
  id            String   @id @default(cuid())
  title         String
  description   String
  imageUrls     String   @default("[]") // JSON array of image URLs

  // Listing type
  listingType   String   @default("SINGLE_CARD") // SINGLE_CARD | MULTI_CARD | COLLECTION | SEALED_PRODUCT | OTHER

  // Card details (for SINGLE_CARD)
  cardName      String?
  cardSetId     String?
  cardSet       CardSet? @relation(fields: [cardSetId], references: [id])
  condition     String?  // "Near Mint", "Lightly Played", etc.
  tcgdexId      String?  // Stable TCGdex card identifier, e.g. "base1-4"

  // Multi-card details (for MULTI_CARD)
  // cardItems blijft als snapshot/legacy. Daadwerkelijke per-item state staat
  // in `cardItemRows ListingCardItem[]` (Fase 27.13) — die worden bij
  // listing-creatie afgeleid uit cardItems en daarna leidend voor partial-sales.
  cardItems     String?  // JSON array: [{cardName, cardSetId, condition, quantity}]

  // Partial-sale support (Fase 27.13). Default false — buyer kan dan alleen
  // de hele listing kopen of er een full-listing proposal voor doen.
  allowPartialSale Boolean @default(false)

  // Collection details (for COLLECTION)
  estimatedCardCount Int?
  conditionRange     String? // e.g. "Lightly Played - Near Mint"

  // Sealed product details (for SEALED_PRODUCT)
  productType   String?  // BOOSTER | ETB | TIN | BOOSTER_BOX | OTHER_SEALED

  // Other/Collectibles details (for OTHER)
  itemCategory  String?  // "Playmat", "Binder", "Figuur", etc.

  // Voorraad (Fase 27.23) — voor SEALED_PRODUCT en OTHER. Bij stockQuantity > 1
  // worden N ListingCardItem-rijen aangemaakt op publish zodat dezelfde
  // partial-sale-infrastructuur gebruikt kan worden voor stock-tracking en
  // buy-quantity-flows. Default 1; voor andere listing-types blijft het 1
  // en heeft het geen effect.
  stockQuantity Int      @default(1)

  // Pricing
  pricingType   String   // FIXED | NEGOTIABLE
  price         Float?   // null if NEGOTIABLE
  // Vraagprijs-indicatie voor NEGOTIABLE listings (Fase 27.31). Optioneel; geeft
  // koper een richtbedrag mee zodat ie niet hoeft te raden wat seller verwacht.
  // Niet bindend — biedingen mogen lager of hoger.
  suggestedPrice Float?

  // Koop-toggles (Fase 27.31)
  // - allowDirectBuy: voor FIXED-listings — knop "Direct Kopen" voor het
  //   gevraagde bedrag wel/niet zichtbaar. Default true. Voor NEGOTIABLE
  //   irrelevant (er is geen vaste prijs).
  // - acceptsOffers: voor FIXED-listings — knop "Bod doen" zichtbaar via chat.
  //   Voor NEGOTIABLE altijd true (geen vaste prijs = altijd onderhandelen).
  //   Voorkomt dat sellers boos worden om lage biedingen op een vaste prijs.
  allowDirectBuy Boolean @default(true)
  acceptsOffers  Boolean @default(true)

  // Shipping
  shippingCost    Float    @default(0)
  deliveryMethod  String   @default("SHIP") // PICKUP | SHIP | BOTH
  freeShipping    Boolean  @default(false)
  carriers        String?  // JSON array: ["POSTNL","DHL","SELF"]
  packageSize     String?  // LETTER | SMALL | MEDIUM | LARGE
  packageCount    Int      @default(1)

  // Pickup-locatie (verplicht als deliveryMethod ∈ {PICKUP, BOTH}). Alleen plaats
  // is publiek zichtbaar; auto-gevuld uit User.city bij listing-creatie en niet
  // editeerbaar in de form.
  pickupCity       String?

  // Pickup-betaal-modi (Fase 27.39). Voor PICKUP/BOTH listings bepalen deze
  // toggles welke betaal-vormen koper mag kiezen:
  // - allowPlatformPickup: koper betaalt vooraf via wallet (escrow), confirm
  //   met code, commission wordt afgetrokken bij release. Veiliger voor beide.
  // - allowExternalPickup: koper betaalt aan verkoper bij ophalen (Tikkie/
  //   contant), geen escrow, geen commission, koper-confirm met 1 klik.
  // Default beide true. Server-side validatie: minstens één moet aan staan
  // voor PICKUP/BOTH listings. Niet relevant voor SHIP-only (altijd PLATFORM).
  allowPlatformPickup Boolean @default(true)
  allowExternalPickup Boolean @default(true)

  // Seller
  sellerId      String
  seller        User     @relation(fields: [sellerId], references: [id])

  // Status (Fase 27): DRAFT | ACTIVE | PAUSED | RESERVED | PARTIALLY_SOLD | SOLD | DELETED.
  // RESERVED = gekoppeld aan een ACCEPTED bundle-offer of partial-balance proposal,
  // tijdelijk niet-koopbaar voor anderen.
  // PARTIALLY_SOLD (Fase 27.13) = MULTI_CARD listing waar één of meer items SOLD
  // zijn maar er nog AVAILABLE items zijn. Blijft publiek zichtbaar met badge.
  status        String   @default("ACTIVE")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  buyerId        String?
  buyer          User?    @relation("ListingBuyer", fields: [buyerId], references: [id])

  conversations  Conversation[]
  watchlistItems Watchlist[]
  upsells        ListingUpsell[]
  labels         ListingLabel[]
  shippingMethods ListingShippingMethod[]
  shippingBundle ShippingBundle?
  proposals      Proposal[]
  bundleProposalListings BundleProposalListing[]
  bundleListing  BundleListing?
  cardItemRows   ListingCardItem[]

  @@index([sellerId])
  @@index([status])
  @@index([cardSetId])
  @@index([listingType])
  @@index([tcgdexId])
}

model ListingLabel {
  id        String   @id @default(cuid())

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // MOET_NU_WEG | HOT_ITEM | TOPSTAAT | ZELDZAAM | HOLO_FOIL | SNEL_VERZONDEN | COMPLETE_SET
  type      String

  // ruby | amber | emerald | sky | violet | rose | indigo | slate | orange | teal
  colorKey  String

  // Snapshot van prijs op creatiemoment (bundle-tarief: 1=€0,99 / 2=€1,69)
  cost      Float

  createdAt DateTime @default(now())

  @@index([listingId])
}

model ListingShippingMethod {
  id               String               @id @default(cuid())
  listingId        String
  listing          Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  shippingMethodId String
  shippingMethod   SellerShippingMethod @relation(fields: [shippingMethodId], references: [id])
  price            Float                // Snapshot of price at creation time

  @@unique([listingId, shippingMethodId])
  @@index([listingId])
}

// ============================================================
// LISTING UPSELLS
// ============================================================

model ListingUpsell {
  id         String   @id @default(cuid())

  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  type       String   // HOMEPAGE_SPOTLIGHT | CATEGORY_HIGHLIGHT | URGENT_LABEL
  startsAt   DateTime @default(now())
  expiresAt  DateTime
  dailyCost  Float
  totalCost  Float

  createdAt  DateTime @default(now())

  @@index([listingId])
  @@index([type, expiresAt])
}

// ============================================================
// SHIPPING BUNDLES
// ============================================================

model ShippingBundle {
  id            String   @id @default(cuid())
  orderNumber   String   @unique @default("")

  buyerId       String
  buyer         User     @relation("BundleBuyer", fields: [buyerId], references: [id])

  sellerId      String
  seller        User     @relation("BundleSeller", fields: [sellerId], references: [id])

  shippingCost  Float
  totalItemCost Float    @default(0)
  totalCost     Float    @default(0) // totalItemCost + shippingCost

  // Selected shipping method
  shippingMethodId String?
  shippingMethod   SellerShippingMethod? @relation(fields: [shippingMethodId], references: [id])

  // Tracking & dates
  trackingUrl        String?
  shippingProofUrls  String?  // JSON array of proof photo URLs
  shippedAt          DateTime?
  deliveredAt        DateTime?

  // Buyer address snapshot at time of purchase
  buyerStreet      String?
  buyerHouseNumber String?
  buyerPostalCode  String?
  buyerCity        String?
  buyerCountry     String?

  refundedAmount Float   @default(0) // Total amount refunded to buyer so far

  // Auto-expire (Fase 28): gevuld door cron `auto-cancel-stale-paid` als
  // bundle 14 dagen op PAID staat zonder shipping. Differentieert mutual-akkoord
  // CANCELLED van system-forced CANCELLED — admin gebruikt dit veld om
  // probleem-sellers te detecteren (zeker als seller eerder een cancel-verzoek
  // afwees). Mutual-akkoord-cancels hebben dit veld leeg.
  autoExpiredAt DateTime?

  // Inpak-vergrendeling (claimsale-merge): zolang dit veld leeg is mag een
  // koper bij een volgende claimsale-checkout items aan deze bundle toevoegen
  // (mits het ook een claimsale-bundle is). Seller flipt 'm met de
  // "Vergrendel voor inpakken"-knop in /dashboard/verkopen, of automatisch
  // bij markAsShipped / pakbon-print. Tegen silent-appends terwijl seller
  // de bestelling al aan het inpakken is.
  lockedForPackingAt DateTime?

  // Audit-log van merge-events: JSON-array van entries
  // `[{ at: ISO, itemNames: string[], itemCount: number, itemTotal: number }]`.
  // Niet bedoeld voor query — alleen rendering in order-detail-tijdlijn zodat
  // seller in één oogopslag ziet dat er items zijn bijgekomen, en wanneer.
  appendHistory String?

  // Status (Fase 27): PENDING | PAID | SCHEDULED | SHIPPED | COMPLETED | CANCELLED | DISPUTED.
  // SCHEDULED = pickup-moment vastgelegd, wacht op code-confirm. Voor EXTERNAL-bundles:
  // PENDING (RESERVED-fase) → SCHEDULED (na pickup-lock) → COMPLETED. PAID/SHIPPED wordt
  // overgeslagen omdat er geen escrow is.
  status        String   @default("PENDING")

  // Payment mode (Fase 27). PLATFORM = escrow via wallet. EXTERNAL = off-platform
  // (Tikkie/contant bij ophalen) — geen wallet-impact, geen commission.
  paymentMode   String   @default("PLATFORM") // PLATFORM | EXTERNAL

  // Delivery method snapshot (Fase 27.39). Bij SHIP gebruikt de bundle de
  // shipping/dispute/tracking-flow; bij PICKUP de pickup-flow met code-confirm
  // (PLATFORM) of 1-knops koper-confirm (EXTERNAL). Default SHIP voor backward
  // compat — bestaande bundles waren altijd SHIP.
  deliveryMethod String  @default("SHIP") // SHIP | PICKUP

  // Reservation-timeout voor EXTERNAL pickup-bundles (now + 14 dagen na seller-accept).
  // Cron `pickup-reservation-timeout` ruimt op zodat listings niet eeuwig vastzitten.
  pickupReservationExpiresAt DateTime?

  cancellationRequests CancellationRequest[]

  // Optional link to source (auction or listing purchase)
  auctionId     String?  @unique
  auction       Auction? @relation(fields: [auctionId], references: [id])
  listingId     String?  @unique
  listing       Listing? @relation(fields: [listingId], references: [id])

  // Multi-listing bundle (Fase 27). Als gevuld: listingId is null en bundle bevat
  // meerdere listings via de BundleListing-join.
  bundleProposalId String? @unique
  bundleProposal   BundleProposal? @relation(fields: [bundleProposalId], references: [id])
  bundleListings   BundleListing[]

  // Pickup-schedule (Fase 27)
  pickupSchedule   PickupSchedule?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         ClaimsaleItem[]
  cardItems     ListingCardItem[] @relation("BundleCardItems")
  dispute       Dispute?

  // Dispute v2 (Fase 40) — greenfield. Bestaande v1-cases blijven op `dispute`,
  // nieuwe cases gaan via `disputeV2`. Beide nullable, exclusive in praktijk.
  disputeV2     DisputeV2?

  // Lightweight admin-tickets voor tracking-stuck / verloren pakket (Fase 40)
  shippingIssues ShippingIssue[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([buyerId, sellerId, status])
  @@index([paymentMode, status])
  @@index([pickupReservationExpiresAt])
}

// ============================================================
// DISPUTES (Geschillen)
// ============================================================

model Dispute {
  id                String   @id @default(cuid())

  shippingBundleId  String   @unique
  shippingBundle    ShippingBundle @relation(fields: [shippingBundleId], references: [id])

  // Opened by buyer
  openedById        String
  openedBy          User     @relation("DisputesOpened", fields: [openedById], references: [id])

  // Dispute details
  reason            String   // NOT_RECEIVED | NOT_AS_DESCRIBED | DAMAGED_IN_TRANSIT
  description       String
  evidenceUrls      String   @default("[]") // JSON array of image URLs

  // Seller response
  sellerResponse       String?
  sellerEvidenceUrls   String?  // JSON array of image URLs
  sellerRespondedAt    DateTime?

  // Proposal system
  partialRefundAmount Float?
  proposedById        String?   // userId of who proposed the partial refund

  // Resolution
  status            String   @default("OPEN") // OPEN | SELLER_RESPONDED | RESOLVED_BUYER | RESOLVED_SELLER | RESOLVED_MUTUAL | ESCALATED
  resolution        String?  // REFUND_FULL | REFUND_PARTIAL | NO_REFUND | MUTUAL_AGREEMENT | ADMIN_DECISION
  resolvedAt        DateTime?
  resolvedById      String?  // Admin userId who resolved (for ESCALATED)

  // Escalation: both parties must agree to admin review
  buyerAcceptsEscalation  Boolean @default(false)
  sellerAcceptsEscalation Boolean @default(false)
  adminNotes              String? // Admin's reasoning for their decision

  // Deadlines
  responseDeadline     DateTime  // Seller has 7 days to respond
  buyerReviewDeadline  DateTime? // Buyer has 7 days after seller responds

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  events DisputeEvent[]

  @@index([openedById])
  @@index([status])
}

model DisputeEvent {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id])

  type       String   // OPENED | SELLER_RESPONDED | PROPOSAL_MADE | PROPOSAL_ACCEPTED | PROPOSAL_WITHDRAWN | ESCALATION_REQUESTED | ESCALATED | REJECTED_TO_ADMIN | RESOLVED
  actorId    String   // userId who performed the action
  detail     String?  // Extra info (e.g. amount, resolution text)

  createdAt  DateTime @default(now())

  @@index([disputeId])
}

// ============================================================
// WALLET / TRANSACTIONS
// ============================================================

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  type           String   // DEPOSIT | PURCHASE | SALE | WITHDRAWAL | FEE | AUCTION_BID | AUCTION_WIN | AUCTION_BID_REFUND
  amount         Float    // Positive for credit, negative for debit
  balanceBefore  Float
  balanceAfter   Float
  description    String

  // Optional references
  relatedAuctionId        String?
  relatedClaimsaleItemId  String?
  relatedShippingBundleId String?
  relatedListingId        String?

  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// MESSAGING
// ============================================================

model Conversation {
  id           String   @id @default(cuid())

  // Optional link to context
  auctionId    String?
  auction      Auction?   @relation(fields: [auctionId], references: [id])
  claimsaleId  String?
  claimsale    Claimsale? @relation(fields: [claimsaleId], references: [id])
  listingId    String?
  listing      Listing?   @relation(fields: [listingId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  proposals    Proposal[]
  bundleProposals BundleProposal[]

  @@index([auctionId])
  @@index([claimsaleId])
  @@index([listingId])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  lastReadAt     DateTime?

  // Chat organization
  status         String    @default("ACTIVE") // ACTIVE | ARCHIVED | DELETED
  archivedAt     DateTime?
  deletedAt      DateTime?

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Message {
  id             String   @id @default(cuid())
  body           String
  imageUrl       String?  // Optional photo attachment
  createdAt      DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])

  // Optional link to a proposal (rendered as special message)
  proposalId     String?
  proposal       Proposal? @relation(fields: [proposalId], references: [id])

  // Optional link to a bundle-offer (Fase 27)
  bundleProposalId String?
  bundleProposal   BundleProposal? @relation(fields: [bundleProposalId], references: [id])

  // Optional link to a pickup-schedule event (Fase 27). Een schedule heeft meerdere
  // messages (propose, respond, reschedule).
  pickupScheduleId String?
  pickupSchedule   PickupSchedule? @relation(fields: [pickupScheduleId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ============================================================
// PROPOSALS (Biedingen/Voorstellen via chat)
// ============================================================

model Proposal {
  id             String   @id @default(cuid())

  listingId      String?
  listing        Listing?  @relation(fields: [listingId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  proposerId     String   // userId who made the proposal

  amount         Float    // Proposed price (totaal voor partial-sale, item-only voor full listing)
  type           String   // BUY | SELL
  status         String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN

  // Payment deadline (for buyers with >= 40% but < 100% balance)
  paymentDeadline DateTime?
  paymentStatus   String?  // AWAITING_PAYMENT | PAID | PAYMENT_FAILED

  // Partial-sale (Fase 27.13). Wanneer gevuld: dit is een gedeeltelijke
  // verkoop-aanvraag voor specifieke ListingCardItem-ids in JSON-array vorm.
  // Bij accept worden die items SOLD i.p.v. de hele listing.
  itemIds         String?
  // Buyer-voorkeur die verzekerde verzending forceert bij seller-accept,
  // analoog aan BundleProposal.requestInsuredShipping.
  requestInsuredShipping Boolean @default(false)

  respondedAt    DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages       Message[]

  @@index([listingId])
  @@index([conversationId])
  @@index([status])
}

// ============================================================
// WATCHLIST & NOTIFICATIONS
// ============================================================

model Watchlist {
  id            String    @id @default(cuid())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  auctionId     String?
  auction       Auction?  @relation(fields: [auctionId], references: [id])

  claimsaleId   String?
  claimsale     Claimsale? @relation(fields: [claimsaleId], references: [id])

  listingId     String?
  listing       Listing?  @relation(fields: [listingId], references: [id])

  createdAt     DateTime  @default(now())

  @@unique([userId, auctionId])
  @@unique([userId, claimsaleId])
  @@unique([userId, listingId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type      String   // OUTBID | AUCTION_WON | ITEM_SOLD | NEW_MESSAGE | WATCHLIST_ENDING
  title     String
  body      String
  link      String?

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============================================================
// REVIEWS & REPUTATION
// ============================================================

model Review {
  id             String   @id @default(cuid())
  rating         Int      // 1-5 (average of subcategories, or standalone)
  comment        String?

  // Subcategory ratings (1-5 each)
  packagingRating    Int?  // Verpakking
  shippingRating     Int?  // Verzendsnelheid
  communicationRating Int? // Communicatie

  reviewerId     String
  reviewer       User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])

  sellerId       String
  seller         User     @relation("ReviewsReceived", fields: [sellerId], references: [id])

  // Optional link to what was purchased
  auctionId       String?
  claimsaleItemId String?
  listingId       String?
  shippingBundleId String?

  // Seller can respond
  sellerResponse  String?

  createdAt      DateTime @default(now())

  @@index([sellerId])
  @@index([reviewerId])
}

// ============================================================
// AUTOBID
// ============================================================

model AutoBid {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])

  maxAmount Float
  isActive  Boolean  @default(true)

  // Fase 27.95: voor BOTH-auctions geeft de autobidder zijn voorkeur op.
  // Elke bid-stap die door autobid wordt geplaatst neemt deze waarde over.
  deliveryChoice String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, auctionId])
  @@index([auctionId, isActive])
}

// ============================================================
// SHOPPING CART
// ============================================================

model CartItem {
  id              String        @id @default(cuid())

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  claimsaleItemId String
  claimsaleItem   ClaimsaleItem @relation(fields: [claimsaleItemId], references: [id], onDelete: Cascade)

  // Snapshot at time of claim (for change detection in cart)
  snapshotPrice    Float?
  snapshotCardName String?

  createdAt       DateTime      @default(now())

  @@unique([userId, claimsaleItemId])
  @@index([userId])
}

// ============================================================
// SUBSCRIPTIONS
// ============================================================

// ============================================================
// ENTERPRISE REQUEST (Fase 31)
// ============================================================
//
// Self-serve aanvraag voor de Enterprise-tier. Admin reviewt handmatig
// in /dashboard/admin/enterprise-requests en zet bij approval een custom
// monthlyPrice via upgradeToTier(...). Eén PENDING per user — bestaande
// PENDING blokkeert nieuwe submit. Niet @unique op userId zodat een
// gebruiker na rejection/cancellation opnieuw kan indienen.

model EnterpriseRequest {
  id                      String   @id @default(cuid())

  userId                  String
  user                    User     @relation("EnterpriseRequester", fields: [userId], references: [id])

  shopName                String
  estimatedMonthlyRevenue Float
  phone                   String
  motivation              String

  status                  String   @default("PENDING") // PENDING | APPROVED | REJECTED

  reviewedAt              DateTime?
  reviewedById            String?
  reviewedBy              User?    @relation("EnterpriseReviewer", fields: [reviewedById], references: [id])
  rejectionReason         String?
  approvedMonthlyPrice    Float?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

model Subscription {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  tier          String   // PRO | UNLIMITED | ENTERPRISE
  billingCycle  String   @default("MONTHLY") // MONTHLY | YEARLY
  status        String   @default("ACTIVE")  // PENDING | ACTIVE | CANCELLED | EXPIRED

  startsAt      DateTime @default(now())
  expiresAt     DateTime
  cancelledAt   DateTime?

  monthlyPrice  Float
  yearlyPrice   Float?
  paymentMethod String?  // For future payment integration (Fase 17)

  // Mollie recurring-billing (Fase 31). mollieCustomerId is gespiegeld
  // op User maar handig per record voor history/debug. mollieSubscriptionId
  // null voor Enterprise (handmatige facturatie buiten Mollie).
  mollieSubscriptionId String?
  mollieCustomerId     String?

  // Payment-cycle status (Fase 31). PAID = recente betaling geslaagd.
  // GRACE = laatste betaling failed, gracePeriodEnd zet 7d-deadline.
  // EXPIRED = grace verlopen + downgrade gedaan.
  paymentStatus    String    @default("PAID") // PAID | FAILED | GRACE | EXPIRED
  gracePeriodEnd   DateTime?
  nextBillingAt    DateTime?

  // Legacy-pricing flag (Fase 31). Bestaande PRO/Unlimited-abonnementen
  // van vóór de prijs/commissie-revisie behouden hun oude tarief tot
  // expiresAt. getEffectiveCommissionRate respecteert deze flag.
  legacyPricing    Boolean   @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status, expiresAt])
  @@index([paymentStatus, gracePeriodEnd])
}

// ============================================================
// APP CONFIG (for commission rates, etc.)
// ============================================================

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON string for flexibility

  updatedAt DateTime @updatedAt
}

// ============================================================
// VERIFICATION REQUESTS
// ============================================================

model VerificationRequest {
  id              String    @id @default(cuid())

  userId          String
  user            User      @relation(fields: [userId], references: [id])

  // Fase 32: type bepaalt of dit een ID- of ADDRESS-aanvraag is.
  // ID gebruikt documentType (ID_CARD/PASSPORT/DRIVERS_LICENSE).
  // ADDRESS gebruikt addressDocumentType (TAX_LETTER/UTILITY_BILL/BANK_STATEMENT/MUNICIPAL_LETTER).
  type            String    @default("ID") // ID | ADDRESS

  documentType        String?   // ID_CARD | PASSPORT | DRIVERS_LICENSE  (alleen bij type=ID)
  addressDocumentType String?   // TAX_LETTER | UTILITY_BILL | BANK_STATEMENT | MUNICIPAL_LETTER  (alleen bij type=ADDRESS)

  frontImageUrl   String
  backImageUrl    String?   // Not needed for passport / not used for ADDRESS

  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectReason    String?
  reviewedById    String?   // Admin who reviewed
  reviewedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}

// ============================================================
// USERNAME HISTORY
// ============================================================

model UsernameHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  oldName   String
  changedAt DateTime @default(now())

  @@index([userId])
}

// ============================================================
// COSMETIC SYSTEM (Ember, Lootboxes, Customization)
// ============================================================

model CosmeticBundle {
  id          String   @id @default(cuid())
  key         String   @unique       // "chapter-1-origins"
  name        String                 // Display name (e.g. "Chapter 1: Origins")
  description String?
  imageUrl    String?                // Chapter cover art
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  items       CosmeticItem[]
}

model CosmeticItem {
  id          String   @id @default(cuid())
  key         String   @unique       // e.g. "flame-dragon-banner", "gold-frame-emblem"
  type        String                 // BANNER | EMBLEM | BACKGROUND | XP_REWARD | EMBER_REWARD
  name        String                 // Display name (i18n nameKey)
  rarity      String                 // UNCOMMON | RARE | EPIC | LEGENDARY | UNIQUE | SHINY
  bundleId    String
  bundle      CosmeticBundle @relation(fields: [bundleId], references: [id])
  assetPath      String?                // Path under /public for visual items
  rewardValue    Int?                   // XP amount or ember amount for reward types
  weight         Int      @default(100) // Relative drop weight within rarity tier
  createdAt      DateTime @default(now())

  ownedItems   OwnedItem[]

  @@index([bundleId])
  @@index([type])
  @@index([rarity])
}

model OwnedItem {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  itemId     String
  item       CosmeticItem @relation(fields: [itemId], references: [id])
  obtainedAt DateTime     @default(now())
  source     String                   // ACHIEVEMENT | LOGIN_STREAK | FOUNDER | ADMIN

  @@unique([userId, itemId])
  @@index([userId])
}

model EmberTransaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Int                    // Positive=earned/purchased, negative=spent
  type          String                 // ACTIVITY_REWARD | WALLET_PURCHASE | LOOTBOX_SPEND | DUPLICATE_REFUND
  description   String
  balanceBefore Int
  balanceAfter  Int
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  action          String   // PLACE_BID | COMPLETE_PURCHASE | COMPLETE_SALE | GIVE_REVIEW | RECEIVE_REVIEW | CREATE_LISTING | DAILY_LOGIN
  metadata        String?  // JSON
  embersAwarded   Int      @default(0)
  ipHash          String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, action, createdAt])
}

// Tiered achievements (CoD-style progression). Each Achievement is one trackable
// metric (e.g. "days-online", "purchases-completed") with 1..N tiers.
// Source of truth in src/lib/achievements.ts; DB mirrors so progress/unlocks
// can be queried and FK'd from UserAchievement.
model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique  // e.g. "days-online"
  name        String
  description String
  category    String            // ARCHIVE | VAULT | TRADER | SOCIAL | MILESTONE | FOUNDER
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  tiers             AchievementTier[]
  userAchievements  UserAchievement[]

  @@index([category])
}

model AchievementTier {
  id                String      @id @default(cuid())
  achievementKey    String
  achievement       Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)
  tier              Int         // 1..N
  threshold         Int
  rewardEmber       Int?
  rewardXP          Int?
  rewardCosmeticKey String?     // optional CosmeticItem.key granted when this tier unlocks

  @@unique([achievementKey, tier])
  @@index([achievementKey])
}

model UserAchievement {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  achievementKey   String
  achievement      Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)
  currentTier      Int         @default(0)  // 0 = not started, N = highest tier unlocked
  acknowledgedTier Int         @default(0)  // highest tier the user has seen a celebration for
  progress         Int         @default(0)  // raw metric value (days, count, amount)
  lastUnlockedAt   DateTime?

  @@unique([userId, achievementKey])
  @@index([userId])
  @@index([achievementKey])
}

// ============================================================
// BUYBACK / INKOOP
// ============================================================

model BuybackRequest {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])

  type             String   @default("COLLECTION") // COLLECTION | BULK
  payoutMethod     String   @default("BANK")        // BANK | STORE_CREDIT
  iban             String?                           // Required when payoutMethod = BANK
  accountHolder    String?                           // Required when payoutMethod = BANK

  totalItems       Int
  estimatedPayout  Float
  storeCreditBonus Float?                            // 20% bonus when payoutMethod = STORE_CREDIT
  finalPayout      Float?                            // Set after inspection (may differ from estimate)

  status           String   @default("PENDING")
  // PENDING → RECEIVED → INSPECTING → APPROVED / PARTIALLY_APPROVED / REJECTED → PAID
  adminNotes       String?
  inspectedById    String?

  // Shipping — verkoper moet binnen `shippingDeadline` (= createdAt + 5 dagen)
  // het pakket onderweg hebben en de Track & Trace via het dashboard invoeren
  // zodat admins de zending kunnen volgen.
  shippingDeadline DateTime?
  shippingCarrier  String?    // PostNL | DPD | DHL | UPS | OTHER
  trackingNumber   String?
  shippedAt        DateTime?  // Gezet zodra de verkoper tracking invult

  receivedAt       DateTime?
  inspectedAt      DateTime?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            BuybackItem[]
  bulkItems        BulkBuybackItem[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// Individual card items for COLLECTION type buyback requests
model BuybackItem {
  id                String   @id @default(cuid())
  buybackRequestId  String
  buybackRequest    BuybackRequest @relation(fields: [buybackRequestId], references: [id], onDelete: Cascade)

  cardId            String            // TCGdex Card.id
  cardName          String            // Snapshot at submission
  cardLocalId       String            // e.g. "054"
  setName           String            // Snapshot
  rarity            String?
  imageUrl          String?

  quantity          Int      @default(1)
  marketPrice       Float             // priceAvg7 (or priceAvg fallback) at submission
  buybackPrice      Float             // marketPrice * 0.85
  isReverse         Boolean  @default(false)

  inspectionStatus  String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason   String?

  // Price-correction flow — admin signaleert prijsfout op de oorspronkelijke
  // calculator-prijs (Marktprijs × 85%). Verkoper moet de gecorrigeerde prijs
  // accepteren (true) of afwijzen (false; item wordt dan REJECTED). Pending
  // (null) blokkeert het finaliseren van de inspectie.
  priceCorrected         Boolean   @default(false)
  correctedMarketPrice   Float?
  correctedBuybackPrice  Float?
  priceCorrectionReason  String?
  userApprovedCorrection Boolean?  // null = pending, true = geaccepteerd, false = afgewezen
  userRespondedAt        DateTime?

  createdAt         DateTime @default(now())

  @@index([buybackRequestId])
}

// ============================================================
// CANCELLATION REQUESTS (Fase 9)
// ============================================================
//
// Either party (buyer of seller) op een PAID bundle kan een annulering
// voorstellen. Wederpartij heeft 7 dagen om te reageren — geen reactie =
// EXPIRED (verkoper blijft leveringsplichtig). Bij ACCEPTED muteert de
// bundle naar CANCELLED en wordt de escrow gerefund.
//
// Niet bedoeld voor SHIPPED bundles — daar treedt het dispute-systeem in.
model CancellationRequest {
  id               String         @id @default(cuid())

  shippingBundleId String
  shippingBundle   ShippingBundle @relation(fields: [shippingBundleId], references: [id])

  proposedById     String
  proposedBy       User           @relation("CancellationProposer", fields: [proposedById], references: [id])

  reason           String   // Buyer: BUYER_WRONG_ITEM | BUYER_DUPLICATE | BUYER_SELLER_UNRESPONSIVE | OTHER. Seller: SELLER_OUT_OF_STOCK | SELLER_DAMAGED | SELLER_SHIPPING_NOT_POSSIBLE | SELLER_BUYER_UNRESPONSIVE | OTHER.
  details          String?

  status           String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | EXPIRED
  respondedAt      DateTime?
  respondedById    String?
  respondedBy      User?    @relation("CancellationResponder", fields: [respondedById], references: [id])
  rejectionNote    String?

  expiresAt        DateTime // createdAt + 7 dagen

  // (Fase 40) Bij EXPIRED-pad zonder shipping wordt automatisch een
  // ShippingIssue aangemaakt voor admin-bemiddeling, ipv stille limbo.
  escalatedShippingIssueId String? @unique
  escalatedShippingIssue   ShippingIssue? @relation("CancellationEscalation", fields: [escalatedShippingIssueId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shippingBundleId])
  @@index([proposedById])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================
// USER BLOCK + REPORT (Fase 7)
// ============================================================
//
// Blocking is symmetric in effect: A blocking B hides their listings/
// conversations on both sides. Existing transactions (bundles, disputes,
// active proposals) are NOT affected — those must still close gracefully.
// Reports go to admin moderation queue, not to the reported user.
model UserBlock {
  id        String   @id @default(cuid())

  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])

  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])

  reason    String?  // optional free text — visible only to the blocker
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model UserReport {
  id          String   @id @default(cuid())

  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])

  reportedId  String
  reported    User     @relation("Reported", fields: [reportedId], references: [id])

  reason      String   // SCAM | SPAM | HARASSMENT | INAPPROPRIATE | FAKE_LISTING | OTHER
  details     String
  evidenceUrl String?

  status        String   @default("OPEN") // OPEN | REVIEWING | DISMISSED | ACTION_TAKEN
  reviewedById  String?
  reviewedBy    User?    @relation("ReportReviewer", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  adminNote     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// WITHDRAWALS / UITBETALINGEN (Fase 6)
// ============================================================
//
// User-initiated payout requests against their wallet balance. Money is
// deducted from User.balance immediately on PENDING (single source of
// truth — refund on REJECTED). Admin approves and manually transfers the
// funds via bank, then marks as PAID. Only one active request (PENDING or
// APPROVED) per user at a time.
model WithdrawalRequest {
  id                String   @id @default(cuid())

  userId            String
  user              User     @relation("WithdrawalUser", fields: [userId], references: [id])

  amount            Float
  iban              String   // snapshot — protects against later IBAN changes
  accountHolderName String   // snapshot

  status            String   @default("PENDING") // PENDING | APPROVED | PAID | REJECTED
  rejectReason      String?
  adminNote         String?

  reviewedById      String?
  reviewedBy        User?    @relation("WithdrawalReviewer", fields: [reviewedById], references: [id])
  approvedAt        DateTime?
  paidAt            DateTime?
  rejectedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Category-based items for BULK type buyback requests
model BulkBuybackItem {
  id                String   @id @default(cuid())
  buybackRequestId  String
  buybackRequest    BuybackRequest @relation(fields: [buybackRequestId], references: [id], onDelete: Cascade)

  category          String            // COMMON | UNCOMMON | RARE | HOLO | REVERSE_HOLO | ULTRA_RARE | POKEBALL_REVERSE | MASTER_BALL_REVERSE | CODE_CARD | COIN | SLEEVES | ENERGY
  quantity          Int      @default(0)
  unitPrice         Float             // Snapshot of per-unit price at submission
  subtotal          Float             // quantity * unitPrice

  approvedQuantity  Int?              // Set after inspection

  createdAt         DateTime @default(now())

  @@index([buybackRequestId])
}

// ============================================================
// ADMIN PANEL (Fase 15)
// ============================================================

// Forward-only audit trail of every admin action. Populated by `logAdminAction`
// helper in `src/lib/admin-audit.ts`. No retroactive backfill.
model AdminAuditLog {
  id          String   @id @default(cuid())

  // adminId nullable per Fase 29 — system-driven events (cron auto-suspend,
  // IP-overlap-detectie) hebben geen menselijke admin. actorType onderscheidt
  // human (USER) van automated (SYSTEM).
  adminId     String?
  admin       User?    @relation("AdminAuditLogActor", fields: [adminId], references: [id])
  actorType   String   @default("USER") // USER | SYSTEM

  action      String   // SUSPEND_USER | LIFT_SUSPENSION | APPROVE_WITHDRAWAL | REJECT_WITHDRAWAL | MARK_PAID | ADMIN_RESOLVE_DISPUTE | REVIEW_VERIFICATION | UPDATE_BUYBACK_STATUS | CONFIRM_BANK_TRANSFER | REVIEW_REPORT | UPDATE_APP_CONFIG | EDIT_SERIES | EDIT_CARDSET | EDIT_CARD | RUN_CRON_MANUALLY | BULK_REMOVE_LISTINGS | BULK_REMOVE_AUCTIONS | BULK_REMOVE_CLAIMSALES | RESET_IBAN_COOLDOWN | FORCE_USERNAME_RESET | BID_IP_OVERLAP | SYSTEM_AUTO_SUSPEND | GRANT_BID_DEPOSIT_EXEMPTION | REVOKE_BID_DEPOSIT_EXEMPTION
  targetType  String   // USER | WITHDRAWAL | DISPUTE | VERIFICATION | BUYBACK | LISTING | AUCTION | CLAIMSALE | APP_CONFIG | SERIES | CARDSET | CARD | CRON | REPORT
  targetId    String?
  metadata    String?  // JSON blob with extra context (amount, oldStatus, newStatus, reason, etc.)

  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([actorType])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// Per-execution log for cron-jobs. Wraps each cron-route via `withCronLogging`
// in `src/lib/cron-logging.ts`. Manual runs from the admin panel set
// `triggeredBy = adminId`; scheduled runs use 'cron'.
model CronRun {
  id              String    @id @default(cuid())

  jobName         String    // 'auto-confirm' | 'auto-resolve-disputes' | etc.
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String    // RUNNING | SUCCESS | FAILED
  itemsProcessed  Int       @default(0)
  errorMessage    String?
  triggeredBy     String?   // 'cron' | adminId

  @@index([jobName, startedAt])
  @@index([status])
}

// ============================================================
// BUNDLE-OFFER + PICKUP (Fase 27)
// ============================================================

// Buyer-initiated multi-listing voorstel in een chat. Buyer kiest 2+ ACTIVE
// listings van zelfde seller + één totaalbedrag + delivery (SHIP=PLATFORM /
// PICKUP=EXTERNAL). Seller accepteert/weigert/counter't. Bij ACCEPT op SHIP met
// 100% saldo: bundle PAID + listings SOLD direct. Bij ACCEPT op SHIP met
// partial saldo: 5d payment-deadline + listings RESERVED. Bij ACCEPT op PICKUP:
// 14d reservation-timeout + listings RESERVED, géén wallet-impact.
model BundleProposal {
  id             String   @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  buyerId  String
  buyer    User   @relation("BundleProposalBuyer", fields: [buyerId], references: [id])

  sellerId String
  seller   User   @relation("BundleProposalSeller", fields: [sellerId], references: [id])

  totalAmount Float

  deliveryMethod   String  // SHIP | PICKUP
  // Shipping-method NIET op offer-creation — seller kiest die pas bij ACCEPT.
  // Wel een buyer-voorkeur: requestInsuredShipping forceert isSigned=true filter
  // op de seller's keuze. Boven €150 / internationaal forceert het bestaande
  // `requiresSignedShipping`-regelwerk dit sowieso.
  requestInsuredShipping Boolean @default(false)

  // PLATFORM (escrow via wallet) of EXTERNAL (off-platform betaling bij ophalen).
  paymentMode String @default("PLATFORM") // PLATFORM | EXTERNAL

  // Voorstel-status: lifecycle van het aanbod zelf.
  status String @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN | EXPIRED | COUNTERED

  // Betalings-status alleen relevant na ACCEPTED. Voor PLATFORM: AWAITING_PAYMENT
  // (partial) → PAID. Voor EXTERNAL: altijd EXTERNAL (geen platform-tracking).
  paymentStatus String? // AWAITING_PAYMENT | PAID | PAYMENT_FAILED | EXTERNAL

  // Voor PLATFORM partial-balance: 5 dagen om bij te storten.
  paymentDeadline DateTime?

  // Voor PENDING-fase: 3 dagen om respons van seller te krijgen.
  expiresAt DateTime?

  // Voor EXTERNAL: 14 dagen om pickup te voltooien. Cron ruimt op.
  pickupReservationExpiresAt DateTime?

  // Counter-bod-keten. Het oude PENDING wordt COUNTERED, een nieuw kind-Proposal
  // wordt aangemaakt met seller→buyer richting (rol-omgekeerd).
  parentProposalId String?
  parentProposal   BundleProposal?  @relation("BundleProposalCounter", fields: [parentProposalId], references: [id])
  childProposals   BundleProposal[] @relation("BundleProposalCounter")

  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listings       BundleProposalListing[]
  shippingBundle ShippingBundle?
  messages       Message[]

  @@index([conversationId])
  @@index([status])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status, expiresAt])
}

// Join: welke listings zitten in een BundleProposal. priceSnapshot is de
// individuele referentieprijs op moment van offer-creatie (informatief).
model BundleProposalListing {
  id               String  @id @default(cuid())

  bundleProposalId String
  bundleProposal   BundleProposal @relation(fields: [bundleProposalId], references: [id], onDelete: Cascade)

  listingId        String
  listing          Listing @relation(fields: [listingId], references: [id])

  priceSnapshot    Float?

  // Partial-quantity (Fase 27.66): per listing kan koper aangeven hoeveel
  // exemplaren hij in de bundel wil.
  // - Voor stocked SEALED/OTHER: gebruik `quantity` — bij accept worden
  //   N items uit cardItemRows aan de bundle gekoppeld (PARTIALLY_SOLD
  //   als er nog over is).
  // - Voor MULTI_CARD met allowPartialSale: gebruik `itemIds` (JSON array
  //   van ListingCardItem.id's) — exacte items worden gekoppeld.
  // - Voor non-stocked single-flip listings (SINGLE_CARD, COLLECTION,
  //   MULTI_CARD zonder allowPartialSale): beide null/1, hele listing flip.
  quantity         Int      @default(1)
  itemIds          String?  // JSON array van ListingCardItem.id (MULTI_CARD partial)

  @@unique([bundleProposalId, listingId])
  @@index([listingId])
}

// Join: welke listings zitten in een ShippingBundle (multi-listing). Wordt pas
// gevuld wanneer een bundle-offer wordt geaccepteerd. listingId is @unique zodat
// een listing maar in één bundle tegelijk kan zitten.
model BundleListing {
  id               String   @id @default(cuid())

  shippingBundleId String
  shippingBundle   ShippingBundle @relation(fields: [shippingBundleId], references: [id], onDelete: Cascade)

  listingId        String   @unique
  listing          Listing  @relation(fields: [listingId], references: [id])

  priceSnapshot    Float

  createdAt        DateTime @default(now())

  @@index([shippingBundleId])
}

// Ophaal-afspraak voor een PICKUP-bundle. Beide partijen kunnen voorstellen
// (PROPOSED), tegenpartij accepteert/weigert. LCLCC-code wordt gegenereerd
// bij bundle-creatie en getoond aan buyer; seller voert hem in bij ophaal.
model PickupSchedule {
  id String @id @default(cuid())

  shippingBundleId String   @unique
  shippingBundle   ShippingBundle @relation(fields: [shippingBundleId], references: [id], onDelete: Cascade)

  proposedById String
  proposedBy   User   @relation("PickupProposer", fields: [proposedById], references: [id])

  proposedFor  DateTime  // gekozen datum
  windowStart  String    // bv. "09:00"
  windowEnd    String    // bv. "12:00"

  status       String    @default("PROPOSED") // PROPOSED | ACCEPTED | REJECTED | RESCHEDULED | COMPLETED

  pickupCode         String   // LCLCC-code (server-generated, bv. N3L97)
  pickupCodeAttempts Int      @default(0)
  pickupLockedUntil  DateTime? // Lockout 1u na 5e foute attempt

  respondedAt    DateTime?
  completedAt    DateTime?
  reminderSentAt DateTime?  // 24u-reminder cron-bookkeeping

  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shippingBundleId, status])
  @@index([status, proposedFor])
}

// ============================================================
// PARTIAL-SALE — per-item state binnen een MULTI_CARD listing (Fase 27.13)
// ============================================================

// Eén rij per item-entry in een MULTI_CARD listing. Bij listing-creatie wordt
// dit afgeleid uit het cardItems-JSON. Daarna leidend voor partial-sales:
// status flipt AVAILABLE → RESERVED (bij accepted partial-sale met partial
// balance) → SOLD, of direct AVAILABLE → SOLD bij full-balance accept.
//
// `quantity` representeert de hoeveelheid binnen DEZE entry (bv. "5x Pikachu");
// status flipt voor de hele entry tegelijk. Per-stuk-quantity-tracking is een
// follow-up.
model ListingCardItem {
  id        String   @id @default(cuid())

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  cardName  String
  cardSetId String?
  tcgdexId  String?  // Fase 27.16: link naar eigen kaart-database voor thumbs + pricing
  condition String?
  quantity  Int      @default(1)

  // AVAILABLE | RESERVED | SOLD
  status    String   @default("AVAILABLE")
  buyerId   String?
  soldAt    DateTime?

  // Wanneer SOLD/RESERVED via een partial-sale: link naar de bundle. Wordt
  // ge-null'd bij cancellation zodat het item weer AVAILABLE kan worden.
  shippingBundleId String?
  shippingBundle   ShippingBundle? @relation("BundleCardItems", fields: [shippingBundleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId, status])
  @@index([shippingBundleId])
}

// ============================================================
// AUCTION RUNNER-UP OFFER (post-Fase-33)
// ============================================================
// Wanneer een veilingwinnaar de 5d-betaaltermijn mist, wordt de veiling NIET
// meer automatisch doorgeschoven. In plaats daarvan krijgt de volgende hoogste
// bieder een AuctionRunnerUpOffer met `status = AWAITING_DECISION` en 72u tijd
// om te accepteren of weigeren. Tijdens dat window:
//   - Auction.paymentStatus = "AWAITING_RUNNER_UP_DECISION"
//   - Auction.winnerId / finalPrice zijn al gezet op de runner-up
//   - GEEN PENDING-bundle, GEEN reserve op de runner-up (geen bid meer)
//
// Bij ACCEPT: PENDING-bundle aangemaakt, reserve via syncReservedBalance,
// 5d-payment-deadline (zelfde flow als originele winnaar).
// Bij DECLINE/EXPIRED: bidderId wordt aan failedBidderIds toegevoegd, volgende
// kandidaat krijgt offer (of PAYMENT_FAILED als geen kandidaat meer of cap bereikt).
model AuctionRunnerUpOffer {
  id               String    @id @default(cuid())
  auctionId        String
  auction          Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId         String
  bidder           User      @relation("RunnerUpBidder", fields: [bidderId], references: [id])
  bidAmount        Float                                                  // het bod van destijds (zonder fee)
  premiumAmount    Float                                                  // 2,9% × bidAmount, gesnapshot bij offer-creation
  deliveryChoice   String?                                                // SHIP | PICKUP, gesnapshot uit bid
  status           String    @default("AWAITING_DECISION")                // AWAITING_DECISION | ACCEPTED | DECLINED | EXPIRED
  decisionDeadline DateTime                                               // createdAt + 72u
  decidedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([auctionId, status])
  @@index([bidderId, status])
}

// ============================================================
// PENDING PLATFORM FEE (post-Fase-33)
// ============================================================
// Schuld-administratie voor niet-inbare boetes/forfaits (BID_DEPOSIT_FORFEIT
// of BID_PAYMENT_FAILURE_FEE). Wordt FIFO afgeroomd bij elke balance-credit
// (deposit, sale-payout, etc.) via wallet-helper `settlePendingFees`. Anti-
// griefing: een wanbetaler kan z'n saldo niet meer leeg houden om de boete
// te ontwijken — eerstvolgende inkomst betaalt de schuld af voordat het
// daadwerkelijke saldo groeit.
model PendingPlatformFee {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String                          // BID_DEPOSIT_FORFEIT | BID_PAYMENT_FAILURE_FEE
  amount           Float                           // Wat er nog open staat (positief, decreert bij settle)
  originalAmount   Float                           // Wat het oorspronkelijk had moeten zijn (immutabel, voor audit)
  description      String
  relatedAuctionId String?
  createdAt        DateTime  @default(now())
  settledAt        DateTime?                       // null = nog open, gevuld = volledig betaald

  @@index([userId, settledAt])
}

// ============================================================
// AUTH TOKENS (Fase 37)
// ============================================================
// Tijdelijke, eenmalig-bruikbare tokens voor password-reset en e-mailverificatie.
// Token-string is cryptografisch random (crypto.randomBytes), opgeslagen plaintext
// omdat 'm verifiëren constant-time gebeurt en de TTL kort is (1u / 24u).
// usedAt = gemarkeerd na succesvol gebruik zodat replay niet werkt.

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime                    // now + 1u
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime                    // now + 24u
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Audit log voor Claude-vision content-moderation op upload.
// Verdict-waarden: "safe" | "blocked" | "skipped_unavailable" | "skipped_no_key"
// Context-waarden: "listing" | "auction" | "avatar" | "chat" | "dispute" | "shipping"
model ImageModerationLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("ImageModerationLogUser", fields: [userId], references: [id], onDelete: SetNull)
  context   String
  verdict   String
  reason    String?
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([verdict, createdAt])
}

// ============================================================
// DISPUTE V2 (Fase 40) — greenfield rewrite
// ============================================================
//
// Naast de bestaande `Dispute`/`DisputeEvent`-modellen (Fase 12 / Fase 28).
// Lopende v1-cases blijven daar tot ze resolved zijn; alle nieuwe disputes
// gaan via dit model. Verschillen met v1:
//   - structured `reasonCategory` (5 hoofd-redenen + sub-categorie) ipv free-text
//   - explicit `MEDIATION`-fase voor proposal-loop (max 5 ronden in actions)
//   - `adminSLADeadline` voor escalation → admin krijgt 5d-flag
//   - `events` linken naar actor + actorType (BUYER/SELLER/ADMIN/SYSTEM)
//   - werkt voor SHIPPED én EXTERNAL-pickup-COMPLETED-bundles
//   - foto-upload-UI bestaat daadwerkelijk (v1 had dead `evidenceUrls`-param)
//
// Refund-correctheid:
//   FULL_REFUND  → bundle CANCELLED, escrow + premium terug naar buyer
//   PARTIAL_REFUND → bundle COMPLETED, refundedAmount updated
//   NO_REFUND    → bundle COMPLETED, geen mutaties
//   RETURN_AND_REFUND → admin-only, FULL_REFUND na proof-of-return
model DisputeV2 {
  id                String   @id @default(cuid())

  bundleId          String   @unique
  bundle            ShippingBundle @relation(fields: [bundleId], references: [id])

  buyerId           String
  buyer             User     @relation("DisputeV2Buyer", fields: [buyerId], references: [id])

  sellerId          String
  seller            User     @relation("DisputeV2Seller", fields: [sellerId], references: [id])

  // Status-flow:
  //   OPEN → seller heeft `responseDeadline` (14d) om te reageren
  //   SELLER_RESPONDED → buyer heeft `buyerReviewDeadline` (14d): accept / reject / propose
  //   MEDIATION → één partij heeft proposedRefund gezet, andere moet reageren
  //   ESCALATED → beide akkoord met admin-review, `adminSLADeadline` (5d) loopt
  //   RESOLVED_BUYER → 100% refund, bundle CANCELLED
  //   RESOLVED_SELLER → geen refund, bundle COMPLETED (bij SHIPPED) of stays
  //   RESOLVED_MUTUAL → partial via mutual agreement
  //   RESOLVED_ADMIN → admin-decision (kan elke uitkomst zijn)
  //   CANCELLED → buyer trekt geschil zelf in (alleen pre-MEDIATION)
  status            String   @default("OPEN")

  // Reden-categorie (hard categorieën, ipv free-text). Sub-categorie bv.
  // "in_transit_stuck_14d" of "delivered_to_wrong_address" voor NOT_RECEIVED.
  reasonCategory    String   // NOT_RECEIVED | NOT_AS_DESCRIBED | DAMAGED | WRONG_ITEM | COUNTERFEIT_SUSPECTED | OTHER
  reasonSubCategory String?

  // Statements
  buyerStatement    String
  sellerStatement   String?

  // Evidence — JSON arrays van upload URLs. Beide partijen kunnen achteraf
  // toevoegen via `addEvidenceV2` (apart van initial statements).
  evidenceBuyer     String   @default("[]")
  evidenceSeller    String   @default("[]")

  // Proposal-systeem (MEDIATION-fase)
  proposedRefund    Float?
  proposedById      String?  // userId van wie het proposal deed

  // Resolution
  finalRefund       Float?   // wat uiteindelijk uitbetaald is
  resolution        String?  // FULL_REFUND | PARTIAL_REFUND | NO_REFUND | RETURN_AND_REFUND
  resolvedAt        DateTime?

  // Admin (alleen bij ESCALATED + RESOLVED_ADMIN)
  adminId           String?
  admin             User?    @relation("DisputeV2Admin", fields: [adminId], references: [id])
  adminNotes        String?
  adminSLADeadline  DateTime? // set bij flip naar ESCALATED, 5d window

  // Generic deadlines
  responseDeadline    DateTime
  buyerReviewDeadline DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  events DisputeV2Event[]

  // Link terug vanuit ShippingIssue als deze hier naar geescaleerd is
  escalatedFromShippingIssueId String? @unique
  escalatedFromShippingIssue   ShippingIssue? @relation("ShippingIssueEscalation", fields: [escalatedFromShippingIssueId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([adminSLADeadline])
}

model DisputeV2Event {
  id          String   @id @default(cuid())
  disputeId   String
  dispute     DisputeV2 @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  // Event-types: OPENED | SELLER_RESPONDED | PROPOSAL | PROPOSAL_ACCEPTED |
  //   PROPOSAL_REJECTED | EVIDENCE_ADDED | ESCALATION_REQUESTED | ESCALATED |
  //   ADMIN_DECISION | AUTO_RESOLVED | CANCELLED
  type        String

  actorId     String?
  actor       User?    @relation("DisputeV2EventActor", fields: [actorId], references: [id])
  actorType   String   // BUYER | SELLER | ADMIN | SYSTEM

  message     String?  // korte tekst getoond in timeline
  metadata    String?  // JSON (bv. proposedAmount, evidenceCount)

  createdAt   DateTime @default(now())

  @@index([disputeId])
}

// ============================================================
// SHIPPING ISSUE (Fase 40) — lightweight admin-ticket
// ============================================================
//
// Voor scenario's waar de zware DisputeV2-flow disproportioneel zou zijn:
//   - tracking blijft hangen op "in transit" > 14 dagen
//   - geen scan-update meer
//   - pakket bij verkeerd adres bezorgd
//
// Buyer kan na 14d sinds shipped een ticket openen. Admin onderzoekt en
// resolved met:
//   RESOLVED_GOODWILL → platform credit tot €50 (Transaction GOODWILL_REFUND)
//   RESOLVED_NO_ACTION → seller wint, ticket dicht
//   ESCALATED_TO_DISPUTE → auto-create DisputeV2 met NOT_RECEIVED + admin-notes
//
// Tijdens OPEN / INVESTIGATING skipt auto-confirm-cron de bundle — voorkomt
// dat escrow released wordt tijdens admin-onderzoek.
model ShippingIssue {
  id          String   @id @default(cuid())

  bundleId    String
  bundle      ShippingBundle @relation(fields: [bundleId], references: [id])

  reporterId  String
  reporter    User    @relation("ShippingIssueReporter", fields: [reporterId], references: [id])

  // TRACKING_STUCK = "in transit" > 14d zonder update
  // NO_SCAN_UPDATE = pakket was eens "in transit" maar tracking is gestopt
  // WRONG_DELIVERY = bezorgd op verkeerd adres (zowel buyer als seller kan dit melden)
  // OTHER          = vrije-tekst
  type        String

  description String

  // Status-flow:
  //   OPEN → admin nog niet gekeken
  //   INVESTIGATING → admin onderzoekt actief (5d-flag voor zelf-tracking)
  //   RESOLVED_GOODWILL → platform refundt tot €50 vanuit goodwill-pot
  //   RESOLVED_NO_ACTION → ticket gesloten zonder actie
  //   ESCALATED_TO_DISPUTE → DisputeV2 aangemaakt
  status      String   @default("OPEN")

  resolution  String?  // free-text admin-notitie

  adminId     String?
  admin       User?    @relation("ShippingIssueAdmin", fields: [adminId], references: [id])

  // Bij RESOLVED_GOODWILL: link naar de Transaction-rij die de credit deed
  goodwillTransactionId String?

  // Bij ESCALATED_TO_DISPUTE: link naar het aangemaakte DisputeV2-record
  escalatedDispute DisputeV2? @relation("ShippingIssueEscalation")

  // Reverse-relatie voor CancellationRequest.escalatedShippingIssue
  cancellationRequest CancellationRequest? @relation("CancellationEscalation")

  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@index([bundleId])
  @@index([reporterId])
  @@index([status])
}
